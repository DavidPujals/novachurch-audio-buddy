<Window x:Class="NovaSetlist.SearchDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add songs"
        Width="420" Height="380"
        MinWidth="320" MinHeight="260"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI" FontSize="13"
        TextOptions.TextFormattingMode="Display"
        FocusManager.FocusedElement="{Binding ElementName=SearchBox}">
    <DockPanel Margin="14,12">
        <TextBlock DockPanel.Dock="Bottom" Text="Enter adds the top match · Esc closes"
                   Foreground="{StaticResource FaintBrush}" FontSize="11" Margin="2,8,0,0" />
        <Grid DockPanel.Dock="Top">
            <TextBox x:Name="SearchBox" MinHeight="30"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     PreviewKeyDown="SearchBox_PreviewKeyDown" />
            <TextBlock Text="Search songs…" Margin="10,0,0,0" VerticalAlignment="Center"
                       Foreground="{StaticResource FaintBrush}" IsHitTestVisible="False">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>
        <ListBox x:Name="ResultList" Margin="0,8,0,0"
                 ItemsSource="{Binding SearchResults}"
                 MouseDoubleClick="ResultList_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <DockPanel Margin="2,0">
                        <TextBlock DockPanel.Dock="Right" Text="{Binding DefaultKey}"
                                   Foreground="{StaticResource DimBrush}"
                                   FontFamily="Consolas" Margin="14,0,4,0" />
                        <TextBlock Text="{Binding Name}" />
                    </DockPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
