<Window x:Class="NovaSetlist.AddSongDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:music="clr-namespace:NovaSetlist.Music"
        Title="Add song manually"
        Width="400" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI" FontSize="13"
        TextOptions.TextFormattingMode="Display"
        FocusManager.FocusedElement="{Binding ElementName=NameBox}">
    <StackPanel Margin="18,16">
        <TextBlock Text="SONG" Style="{StaticResource SectionHeader}" Margin="1,0,0,6" />
        <TextBox x:Name="NameBox" MinHeight="30" TextChanged="NameBox_TextChanged" />

        <TextBlock Text="KEY" Style="{StaticResource SectionHeader}" Margin="1,14,0,6" />
        <ComboBox x:Name="KeyBox" IsEditable="True" Width="130" HorizontalAlignment="Left"
                  FontFamily="Consolas"
                  ItemsSource="{x:Static music:Keys.StandardKeys}" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancel" MinWidth="76" IsCancel="True" />
            <Button x:Name="AddButton" Content="Add" MinWidth="76" Margin="6,0,0,0" IsDefault="True"
                    IsEnabled="False" Click="Add_Click" />
        </StackPanel>
    </StackPanel>
</Window>
