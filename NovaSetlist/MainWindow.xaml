<Window x:Class="NovaSetlist.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:NovaSetlist.ViewModels"
        xmlns:ui="clr-namespace:NovaSetlist.Ui"
        Title="Audio Buddy"
        Width="1180" Height="640"
        MinWidth="500" MinHeight="300"
        Background="{StaticResource BackBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI" FontSize="13"
        TextOptions.TextFormattingMode="Display"
        FocusManager.FocusedElement="{Binding ElementName=SearchBox}">
    <Window.Resources>

        <!-- Row number cell: shows the number, morphs into ▶ on hover / while playing -->
        <Style x:Key="PlayNumberButton" TargetType="Button" BasedOn="{StaticResource IconButton}">
            <Setter Property="ToolTip" Value="Cue this song's countdown" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome" Background="Transparent" CornerRadius="5" MinWidth="28">
                            <Grid>
                                <TextBlock x:Name="Num" Text="{Binding Index}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontFamily="Consolas" FontSize="14"
                                           Foreground="{StaticResource FaintBrush}" />
                                <TextBlock x:Name="Play" Text="▶" Visibility="Collapsed"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="12" Foreground="{StaticResource DimBrush}" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource HoverBrush}" />
                                <Setter TargetName="Num" Property="Visibility" Value="Hidden" />
                                <Setter TargetName="Play" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                <Setter TargetName="Num" Property="Visibility" Value="Hidden" />
                                <Setter TargetName="Play" Property="Visibility" Value="Visible" />
                                <Setter TargetName="Play" Property="Foreground" Value="{StaticResource GreenBrush}" />
                            </DataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsPlaying}" Value="True" />
                                    <Condition Binding="{Binding DataContext.Timecode.PlayState, RelativeSource={RelativeSource AncestorType=Window}}" Value="cued" />
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="Play" Property="Foreground" Value="{StaticResource AmberBrush}" />
                            </MultiDataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                    <Setter Property="ToolTip" Value="Stop" />
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsPlaying}" Value="True" />
                        <Condition Binding="{Binding DataContext.Timecode.PlayState, RelativeSource={RelativeSource AncestorType=Window}}" Value="cued" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="ToolTip" Value="Waiting for timecode — click again to start now" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Compact-row variant: the KEY sits in the play cell instead of the number -->
        <Style x:Key="PlayKeyButton" TargetType="Button" BasedOn="{StaticResource IconButton}">
            <Setter Property="ToolTip" Value="Cue this song's countdown" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome" Background="Transparent" CornerRadius="5" MinWidth="42">
                            <Grid>
                                <TextBlock x:Name="Num"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontFamily="Consolas" FontSize="13" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding SelectedKey}" />
                                            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedKey}" Value="">
                                                    <Setter Property="Text" Value="—" />
                                                    <Setter Property="Foreground" Value="{StaticResource FaintBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock x:Name="Play" Text="▶" Visibility="Collapsed"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="12" Foreground="{StaticResource DimBrush}" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource HoverBrush}" />
                                <Setter TargetName="Num" Property="Visibility" Value="Hidden" />
                                <Setter TargetName="Play" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                <Setter TargetName="Num" Property="Visibility" Value="Hidden" />
                                <Setter TargetName="Play" Property="Visibility" Value="Visible" />
                                <Setter TargetName="Play" Property="Foreground" Value="{StaticResource GreenBrush}" />
                            </DataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsPlaying}" Value="True" />
                                    <Condition Binding="{Binding DataContext.Timecode.PlayState, RelativeSource={RelativeSource AncestorType=Window}}" Value="cued" />
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="Play" Property="Foreground" Value="{StaticResource AmberBrush}" />
                            </MultiDataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                    <Setter Property="ToolTip" Value="Stop" />
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsPlaying}" Value="True" />
                        <Condition Binding="{Binding DataContext.Timecode.PlayState, RelativeSource={RelativeSource AncestorType=Window}}" Value="cued" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="ToolTip" Value="Waiting for timecode — click again to start now" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Right-click menu for a setlist row -->
        <ContextMenu x:Key="RowMenu">
            <MenuItem Header="Edit key, leader &amp; colour" Click="RowMenuEdit_Click" />
            <Separator Style="{StaticResource MenuSeparator}" />
            <MenuItem Header="Remove from service" Click="RowMenuRemove_Click" />
        </ContextMenu>

        <!-- Instantiated per row only while its editor is open (see the ContentControl trigger) -->
        <DataTemplate x:Key="RowEditorTemplate" DataType="{x:Type vm:SetItemViewModel}">
            <WrapPanel Margin="46,0,8,8" Orientation="Horizontal">
                <StackPanel Orientation="Horizontal" Margin="0,0,18,4">
                    <TextBlock Text="KEY" Style="{StaticResource SectionHeader}"
                               FontSize="10" Margin="0,0,7,0" />
                    <ComboBox IsEditable="True" VerticalAlignment="Center"
                              Width="84" FontFamily="Consolas"
                              ItemsSource="{Binding DataContext.StandardKeys, RelativeSource={RelativeSource AncestorType=Window}}"
                              Text="{Binding SelectedKey, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,18,4">
                    <TextBlock Text="LEADER" Style="{StaticResource SectionHeader}"
                               FontSize="10" Margin="0,0,7,0" />
                    <ComboBox IsEditable="True" VerticalAlignment="Center"
                              Width="160"
                              ItemsSource="{Binding DataContext.Leaders, RelativeSource={RelativeSource AncestorType=Window}}"
                              Text="{Binding Leader}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,18,4">
                    <TextBlock Text="BPM" Style="{StaticResource SectionHeader}"
                               FontSize="10" Margin="0,0,7,0" />
                    <TextBox Width="52" VerticalAlignment="Center" FontFamily="Consolas"
                             Text="{Binding Bpm, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <ItemsControl ItemsSource="{x:Static ui:RowColors.Tokens}"
                              VerticalAlignment="Center" Margin="0,0,0,4">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource Swatch}" Click="Swatch_Click"
                                    Background="{Binding Converter={StaticResource ColorTokenBrush}, ConverterParameter=swatch}">
                                <TextBlock Text="✓" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource TextBrush}">
                                    <TextBlock.Visibility>
                                        <MultiBinding Converter="{StaticResource EqualsToVisibility}">
                                            <Binding Path="." />
                                            <Binding Path="DataContext.Color" RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                        </MultiBinding>
                                    </TextBlock.Visibility>
                                </TextBlock>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </WrapPanel>
        </DataTemplate>

        <!-- Full-width row: name · key + enharmonic · leader · edit/remove -->
        <DataTemplate x:Key="RowTemplateWide" DataType="{x:Type vm:SetItemViewModel}">
            <Border BorderBrush="{StaticResource HairlineBrush}" BorderThickness="0,0,0,1"
                    ContextMenu="{StaticResource RowMenu}">
                <Grid Background="{Binding Color, Converter={StaticResource ColorTokenBrush}, ConverterParameter=tint}">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Opacity" Value="1" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                    <Setter Property="Opacity" Value="0.38" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Rectangle Grid.Column="0" Width="3"
                               Fill="{Binding Color, Converter={StaticResource ColorTokenBrush}, ConverterParameter=bar}" />

                    <StackPanel Grid.Column="1">
                        <Grid Margin="0,8,4,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40" />
                                <ColumnDefinition Width="3*" MinWidth="70" />
                                <ColumnDefinition Width="56" />
                                <ColumnDefinition Width="74" />
                                <ColumnDefinition Width="2*" MinWidth="80" MaxWidth="180" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Margin="0,0,4,0" Style="{StaticResource PlayNumberButton}"
                                    Command="{Binding DataContext.PlayCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}" />

                            <!-- Song name: drag to reorder, click to mark completed -->
                            <Border Grid.Column="1" Background="Transparent" Cursor="SizeNS"
                                    ToolTip="Drag to reorder · click to mark completed"
                                    MouseLeftButtonDown="RowGrip_MouseLeftButtonDown"
                                    MouseMove="RowGrip_MouseMove"
                                    MouseLeftButtonUp="RowGrip_MouseLeftButtonUp"
                                    LostMouseCapture="RowGrip_LostMouseCapture">
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                           FontSize="14" TextTrimming="CharacterEllipsis" Margin="0,0,10,0" />
                            </Border>

                            <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                       FontFamily="Consolas" FontSize="15" FontWeight="Bold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding SelectedKey}" />
                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedKey}" Value="">
                                                <Setter Property="Text" Value="—" />
                                                <Setter Property="Foreground" Value="{StaticResource FaintBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Grid.Column="3" Text="{Binding EquivalentText}" VerticalAlignment="Center"
                                       Foreground="{StaticResource DimBrush}"
                                       FontFamily="Consolas" Margin="0,0,10,0" />

                            <TextBlock Grid.Column="4" VerticalAlignment="Center" FontSize="13"
                                       TextTrimming="CharacterEllipsis" Margin="0,0,8,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding Leader}" />
                                        <Setter Property="Foreground" Value="{StaticResource DimBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Leader}" Value="">
                                                <Setter Property="Text" Value="—" />
                                                <Setter Property="Foreground" Value="{StaticResource FaintBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <StackPanel Grid.Column="5" Orientation="Horizontal">
                                <Button Click="EditRow_Click" ToolTip="Edit key, leader and colour">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                            <Setter Property="Content" Value="✎" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="Content" Value="✓" />
                                                    <Setter Property="Foreground" Value="{StaticResource GreenBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Style="{StaticResource IconButton}" Content="✕" ToolTip="Remove" Margin="4,0,0,0"
                                        Command="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}" />
                            </StackPanel>
                        </Grid>

                        <ContentControl Focusable="False">
                            <ContentControl.Style>
                                <Style TargetType="ContentControl">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Content" Value="{Binding}" />
                                            <Setter Property="ContentTemplate" Value="{StaticResource RowEditorTemplate}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ContentControl.Style>
                        </ContentControl>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Compact row for narrow windows: name gets the space, right-click for actions -->
        <DataTemplate x:Key="RowTemplateNarrow" DataType="{x:Type vm:SetItemViewModel}">
            <Border BorderBrush="{StaticResource HairlineBrush}" BorderThickness="0,0,0,1"
                    ContextMenu="{StaticResource RowMenu}">
                <Grid Background="{Binding Color, Converter={StaticResource ColorTokenBrush}, ConverterParameter=tint}">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Opacity" Value="1" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                    <Setter Property="Opacity" Value="0.38" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Rectangle Grid.Column="0" Width="3"
                               Fill="{Binding Color, Converter={StaticResource ColorTokenBrush}, ConverterParameter=bar}" />

                    <StackPanel Grid.Column="1">
                        <Grid Margin="0,8,4,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="46" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Key doubles as the play button here -->
                            <Button Grid.Column="0" Margin="0,0,4,0" Style="{StaticResource PlayKeyButton}"
                                    Command="{Binding DataContext.PlayCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}" />

                            <Border Grid.Column="1" Background="Transparent" Cursor="SizeNS"
                                    ToolTip="Drag to reorder · click to mark completed · right-click for actions"
                                    MouseLeftButtonDown="RowGrip_MouseLeftButtonDown"
                                    MouseMove="RowGrip_MouseMove"
                                    MouseLeftButtonUp="RowGrip_MouseLeftButtonUp"
                                    LostMouseCapture="RowGrip_LostMouseCapture">
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                           FontSize="14" TextTrimming="CharacterEllipsis" Margin="0,0,8,0" />
                            </Border>

                            <!-- Leader at the right edge -->
                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="0,0,6,0"
                                       FontSize="12.5" MaxWidth="120" TextTrimming="CharacterEllipsis">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding Leader}" />
                                        <Setter Property="Foreground" Value="{StaticResource DimBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Leader}" Value="">
                                                <Setter Property="Text" Value="—" />
                                                <Setter Property="Foreground" Value="{StaticResource FaintBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <ContentControl Focusable="False">
                            <ContentControl.Style>
                                <Style TargetType="ContentControl">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Content" Value="{Binding}" />
                                            <Setter Property="ContentTemplate" Value="{StaticResource RowEditorTemplate}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ContentControl.Style>
                        </ContentControl>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <DockPanel Margin="16,14,16,12">

        <!-- Top bar: search · actions (folds away below the height breakpoint) -->
        <StackPanel DockPanel.Dock="Top">
            <DockPanel LastChildFill="True">
                <DockPanel.Style>
                    <Style TargetType="DockPanel">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsShort}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DockPanel.Style>
                <Button DockPanel.Dock="Right" Margin="10,0,0,0" Content="Settings" Click="Settings_Click" />
                <Button DockPanel.Dock="Right" Margin="6,0,0,0" Content="Copy as text" Command="{Binding CopyAsTextCommand}" />
                <Button DockPanel.Dock="Right" Margin="6,0,0,0" Content="New service" Command="{Binding NewServiceCommand}" />
                <Button DockPanel.Dock="Right" Margin="6,0,0,0" Content="Refresh" Command="{Binding RefreshCommand}" />
                <Button DockPanel.Dock="Right" Margin="10,0,0,0" Content="+ Add manually" Click="AddManually_Click" />

                <Grid>
                    <TextBox x:Name="SearchBox"
                             MinHeight="30"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             TextChanged="SearchBox_TextChanged"
                             PreviewKeyDown="SearchBox_PreviewKeyDown"
                             LostKeyboardFocus="SearchBox_LostKeyboardFocus" />
                    <TextBlock Text="Search songs — Enter adds the top match"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource FaintBrush}"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Popup x:Name="SearchPopup"
                           PlacementTarget="{Binding ElementName=SearchBox}"
                           Placement="Bottom"
                           StaysOpen="False"
                           AllowsTransparency="True"
                           Width="{Binding ActualWidth, ElementName=SearchBox}">
                        <Border Margin="0,3,8,10"
                                Background="{StaticResource FieldBrush}"
                                BorderBrush="{StaticResource HairlineBrush}"
                                BorderThickness="1" CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.45" />
                            </Border.Effect>
                            <ListBox x:Name="SearchList"
                                     MaxHeight="260"
                                     ItemsSource="{Binding SearchResults}"
                                     PreviewMouseLeftButtonUp="SearchList_PreviewMouseLeftButtonUp">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="2,0">
                                            <TextBlock DockPanel.Dock="Right" Text="{Binding DefaultKey}"
                                                       Foreground="{StaticResource DimBrush}"
                                                       FontFamily="Consolas" Margin="14,0,4,0" />
                                            <TextBlock DockPanel.Dock="Right"
                                                       Text="{Binding Bpm, StringFormat={}{0} bpm}"
                                                       Foreground="{StaticResource FaintBrush}"
                                                       FontFamily="Consolas" Margin="14,0,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Bpm}" Value="">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Name}" />
                                        </DockPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Popup>
                </Grid>
            </DockPanel>

            <!-- Status line with bridge-style dot (folds away with the top bar) -->
            <StackPanel Orientation="Horizontal" Margin="2,9,0,10">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsShort}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="●" FontSize="9" VerticalAlignment="Center" Margin="0,1,7,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource FaintBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatusState}" Value="ok">
                                    <Setter Property="Foreground" Value="{StaticResource GreenBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding StatusState}" Value="cached">
                                    <Setter Property="Foreground" Value="{StaticResource AmberBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding StatusState}" Value="error">
                                    <Setter Property="Foreground" Value="{StaticResource RedBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource DimBrush}"
                           FontSize="12" TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </StackPanel>

        <!-- Footer -->
        <Grid DockPanel.Dock="Bottom" Margin="2,8,0,0">
            <TextBlock Text="{Binding FooterText}" Foreground="{StaticResource FaintBrush}" FontSize="12" />
        </Grid>

        <!-- Main area: setlist left · timecode right -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="2*" MinWidth="150" MaxWidth="290" />
            </Grid.ColumnDefinitions>

            <!-- Left: service order -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="2,0,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="SERVICE ORDER" Style="{StaticResource SectionHeader}"
                               VerticalAlignment="Center" />
                    <Rectangle Grid.Column="1" Height="1" Margin="10,1,0,0" VerticalAlignment="Center"
                               Fill="{StaticResource HairlineBrush}" />
                </Grid>

                <Grid Grid.Row="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="SetlistItems" ItemsSource="{Binding Items}">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Setter Property="ItemTemplate" Value="{StaticResource RowTemplateWide}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsNarrow}" Value="True">
                                            <Setter Property="ItemTemplate" Value="{StaticResource RowTemplateNarrow}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Empty state -->
                    <TextBlock Text="No songs yet — add one from the search or the ☰ menu"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{StaticResource FaintBrush}" FontSize="13"
                               TextWrapping="Wrap" TextAlignment="Center" Margin="12,0"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Items.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Grid>

            <!-- Divider -->
            <Rectangle Grid.Column="1" Width="1" Margin="16,2" Fill="{StaticResource HairlineBrush}" />

            <!-- Right: LTC timecode viewer -->
            <StackPanel Grid.Column="2" DataContext="{Binding Timecode}">
                <Grid Margin="2,0,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="TIMECODE" Style="{StaticResource SectionHeader}"
                               VerticalAlignment="Center" />
                    <Rectangle Grid.Column="1" Height="1" Margin="10,1,0,0" VerticalAlignment="Center"
                               Fill="{StaticResource HairlineBrush}" />

                    <!-- ☰ replaces the hidden top bar when the window is short.
                         DataContext override: the menu commands live on the main VM. -->
                    <Button Grid.Column="2" Content="☰" FontSize="13" MinHeight="22"
                            Margin="8,0,0,0" Click="MenuButton_Click" ToolTip="Menu"
                            DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsShort}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Add songs…" Click="MenuAddSongs_Click" />
                                <MenuItem Header="Add manually…" Click="AddManually_Click" />
                                <Separator Style="{StaticResource MenuSeparator}" />
                                <MenuItem Header="Refresh" Command="{Binding RefreshCommand}" />
                                <MenuItem Header="New service" Command="{Binding NewServiceCommand}" />
                                <MenuItem Header="Copy as text" Command="{Binding CopyAsTextCommand}" />
                                <Separator Style="{StaticResource MenuSeparator}" />
                                <MenuItem Header="Settings…" Click="Settings_Click" />
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </Grid>

                <Viewbox StretchDirection="DownOnly" Stretch="Uniform"
                         HorizontalAlignment="Center">
                    <Viewbox.Style>
                        <Style TargetType="Viewbox">
                            <Setter Property="Margin" Value="4,16,4,3" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.IsShort, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                    <Setter Property="Margin" Value="4,4,4,1" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Viewbox.Style>
                    <TextBlock Text="{Binding TimecodeText}"
                               FontFamily="Consolas" FontWeight="Bold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontSize" Value="34" />
                                <Setter Property="Foreground" Value="{StaticResource FaintBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsShort, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                        <Setter Property="FontSize" Value="24" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding TcState}" Value="signal">
                                        <Setter Property="Foreground" Value="{StaticResource DimBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding TcState}" Value="locked">
                                        <Setter Property="Foreground" Value="{StaticResource GreenBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Viewbox>

                <TextBlock Text="{Binding RateText}"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource DimBrush}" FontSize="11.5"
                           TextTrimming="CharacterEllipsis">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.IsShort, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.IsShort, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="●  SIGNAL" FontSize="11" FontWeight="Bold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource FaintBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SignalOn}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource GreenBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="●  LOCK" FontSize="11" FontWeight="Bold" Margin="22,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource FaintBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LockOn}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource GreenBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!-- Now playing countdown -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Margin" Value="2,20,0,2" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.IsShort, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                    <Setter Property="Margin" Value="2,8,0,2" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="NOW PLAYING" Style="{StaticResource SectionHeader}" />
                    <Rectangle Grid.Column="1" Height="1" Margin="10,1,0,0" VerticalAlignment="Center"
                               Fill="{StaticResource HairlineBrush}" />
                </Grid>

                <TextBlock Text="hover a song number and click ▶"
                           HorizontalAlignment="Center" Margin="0,10,0,0"
                           Foreground="{StaticResource FaintBrush}" FontSize="11.5" TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding NowPlayingName}" Value="">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding NowPlayingName}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="{Binding NowPlayingName}" HorizontalAlignment="Center"
                               Foreground="{StaticResource DimBrush}" FontSize="12.5"
                               TextTrimming="CharacterEllipsis" MaxWidth="270">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Margin" Value="0,8,0,2" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsShort, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                        <Setter Property="Margin" Value="0,4,0,1" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding NowPlayingBpm}" HorizontalAlignment="Center" Margin="0,0,0,2"
                               FontFamily="Consolas" FontWeight="Bold" FontSize="12"
                               Foreground="{StaticResource DimBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding NowPlayingBpm}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding CountdownText}" HorizontalAlignment="Center"
                               FontFamily="Consolas" FontWeight="Bold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontSize" Value="30" />
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsShort, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                        <Setter Property="FontSize" Value="24" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CountdownState}" Value="warn">
                                        <Setter Property="Foreground" Value="{StaticResource AmberBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CountdownState}" Value="over">
                                        <Setter Property="Foreground" Value="{StaticResource RedBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CountdownState}" Value="up">
                                        <Setter Property="Foreground" Value="{StaticResource DimBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding CountdownSub}" HorizontalAlignment="Center"
                               Foreground="{StaticResource DimBrush}" FontSize="11"
                               TextWrapping="Wrap" TextAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsShort, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!-- Live key detection -->
                <StackPanel DataContext="{Binding DataContext.KeyDetect, RelativeSource={RelativeSource AncestorType=Window}}">
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Margin" Value="2,20,0,2" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsShort, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                        <Setter Property="Margin" Value="2,3,0,1" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="KEY" Style="{StaticResource SectionHeader}" />
                        <Rectangle Grid.Column="1" Height="1" Margin="10,1,0,0" VerticalAlignment="Center"
                                   Fill="{StaticResource HairlineBrush}" />
                    </Grid>

                    <TextBlock Text="{Binding KeyText}" HorizontalAlignment="Center"
                               FontFamily="Consolas" FontWeight="Bold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontSize" Value="26" />
                                <Setter Property="Margin" Value="0,8,0,2" />
                                <Setter Property="Foreground" Value="{StaticResource FaintBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsShort, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                        <Setter Property="FontSize" Value="20" />
                                        <Setter Property="Margin" Value="0,4,0,1" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding KeyState}" Value="detected">
                                        <Setter Property="Foreground" Value="{StaticResource GreenBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding KeyState}" Value="listening">
                                        <Setter Property="Foreground" Value="{StaticResource DimBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding KeySub}" HorizontalAlignment="Center"
                               Foreground="{StaticResource DimBrush}" FontSize="11"
                               TextTrimming="CharacterEllipsis" MaxWidth="270">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsShort, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!-- Live SPL(A) meter (optional — enabled in Settings) -->
                <StackPanel DataContext="{Binding DataContext.Spl, RelativeSource={RelativeSource AncestorType=Window}}"
                            Visibility="{Binding IsEnabled, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Margin" Value="2,20,0,2" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsShort, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                        <Setter Property="Margin" Value="2,3,0,1" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="SPL" Style="{StaticResource SectionHeader}" />
                        <Rectangle Grid.Column="1" Height="1" Margin="10,1,0,0" VerticalAlignment="Center"
                                   Fill="{StaticResource HairlineBrush}" />
                    </Grid>

                    <TextBlock Text="{Binding SplText}" HorizontalAlignment="Center"
                               FontFamily="Consolas" FontWeight="Bold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontSize" Value="26" />
                                <Setter Property="Margin" Value="0,8,0,2" />
                                <Setter Property="Foreground" Value="{StaticResource FaintBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsShort, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                        <Setter Property="FontSize" Value="20" />
                                        <Setter Property="Margin" Value="0,4,0,1" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SplState}" Value="green">
                                        <Setter Property="Foreground" Value="{StaticResource GreenBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SplState}" Value="yellow">
                                        <Setter Property="Foreground" Value="{StaticResource AmberBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SplState}" Value="red">
                                        <Setter Property="Foreground" Value="{StaticResource RedBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding SplSub}" HorizontalAlignment="Center"
                               Foreground="{StaticResource DimBrush}" FontSize="11"
                               TextTrimming="CharacterEllipsis" MaxWidth="270">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsShort, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

            </StackPanel>
        </Grid>

    </DockPanel>
</Window>
